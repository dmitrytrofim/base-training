{
  "name": "base-training-v",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "test": "vitest",
    "preview": "vite preview",
    "watch javascript index": "node --watch --watch-path=./javascript javascript/index.js",
    "watch typescript index": "node --watch --watch-path=./typescript --import tsx typescript/index.ts",
    "watch nodejs index": "node --watch --import tsx nodejs/index.js",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.1.0",
    "eslint-plugin-oxlint": "~1.57.0",
    "eslint-plugin-vue": "~10.8.0",
    "jsdom": "^29.0.1",
    "npm-run-all2": "^8.0.4",
    "sass": "^1.98.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.2",
    "vite-plugin-page-reload": "^0.2.3",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.1",
    "vue-tsc": "^3.2.6"
  }
}